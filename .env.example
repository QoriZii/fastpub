# Model configuration
# FASTPUB_MODEL auto-detects provider from model name (deepseek-* → deepseek, else xai)
# Override with FASTPUB_PROVIDER if needed
FASTPUB_MODEL=grok-3
# FASTPUB_PROVIDER=xai

# xAI API credentials
XAI_API_KEY=xai-...
# XAI_MODEL=grok-3  (legacy, use FASTPUB_MODEL instead)

# DeepSeek API credentials
# DEEPSEEK_API_KEY=sk-...
# FASTPUB_MODEL=deepseek-v4-flash

# Output directory (where analysis.json and rendered files go)
FASTPUB_OUTDIR=examples/

# Logging level: debug | info | warn | error
# LOG_LEVEL=info
